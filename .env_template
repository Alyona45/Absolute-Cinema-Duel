# Database — full connection string
DATABASE_URL=postgresql+psycopg2://your_db_user:your_db_password@localhost:5432/your_db_name

# JWT — generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
